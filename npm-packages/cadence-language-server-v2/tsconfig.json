{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "WebWorker"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
